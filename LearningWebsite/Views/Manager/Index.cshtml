@using LearningWebsite.Models

@{
    ViewData["Title"] = "Manager Dashboard";
    var manager = ViewBag.Manager as ApplicationUser;
    var teamMembers = ViewBag.TeamMembers as List<ApplicationUser> ?? new List<ApplicationUser>();
    var teamMemberCount = ViewBag.TeamMemberCount as int? ?? 0;
    var allAssignments = ViewBag.AllAssignments as PaginatedList<LearningAssignment> ?? new PaginatedList<LearningAssignment>(new List<LearningAssignment>(), 0, 1, 10);
    var totalAssignments = ViewBag.TotalAssignments as int? ?? 0;
    var completedAssignments = ViewBag.CompletedAssignments as int? ?? 0;
    var inProgressAssignments = ViewBag.InProgressAssignments as int? ?? 0;
    var overdueAssignments = ViewBag.OverdueAssignments as int? ?? 0;
    var memberStats = ViewBag.MemberStats as Dictionary<int, dynamic> ?? new Dictionary<int, dynamic>();
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-4">Manager Dashboard</h1>
                    <p class="text-muted lead">Welcome, <strong>@User.Identity?.Name</strong></p>
                </div>
                <div>
                    <a asp-action="TeamMetrics" class="btn btn-primary btn-lg">
                        <i class="fas fa-chart-line"></i> View Team Learning Metrics
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Metrics Cards Row 1: Team Info -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-left-primary shadow h-100">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Team Members</div>
                            <div class="h3 mb-0 font-weight-bold">@teamMemberCount</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-users fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-left-success shadow h-100">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Total Assignments</div>
                            <div class="h3 mb-0 font-weight-bold">@totalAssignments</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-tasks fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-left-info shadow h-100">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Completed</div>
                            <div class="h3 mb-0 font-weight-bold">@completedAssignments</div>
                            <small class="text-muted">@inProgressAssignments In Progress</small>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-left-warning shadow h-100">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Overdue</div>
                            <div class="h3 mb-0 font-weight-bold text-danger">@overdueAssignments</div>
                            @if (overdueAssignments > 0)
                            {
                                <small class="text-danger"><i class="fas fa-exclamation-triangle"></i> Needs Attention</small>
                            }
                            else
                            {
                                <small class="text-success"><i class="fas fa-check"></i> All on Track</small>
                            }
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clock fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Assigned Learnings Section -->
    @if (allAssignments.Any())
    {
        <div class="card shadow mb-4">
            <div class="card-header py-3 bg-success text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold">
                        <i class="fas fa-list-check"></i> All Team Assigned Learnings
                    </h6>
                    <span class="badge bg-light text-dark">@allAssignments.Count Total</span>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-sm" id="assignmentsTable">
                        <thead class="table-light">
                            <tr>
                                <th>Employee</th>
                                <th>Learning Title</th>
                                <th>Category</th>
                                <th>Status</th>
                                <th>Progress</th>
                                <th>Assigned Date</th>
                                <th>Due Date</th>
                                <th>Days Left</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var assignment in allAssignments)
                            {
                                var daysLeft = (assignment.DueDate - DateTime.Now.Date).Days;
                                var isOverdue = daysLeft < 0 && assignment.Status != "Completed";
                                var daysLeftClass = isOverdue ? "text-danger" : daysLeft <= 7 ? "text-warning" : "text-success";

                                <tr class="@(isOverdue ? "table-danger" : "")">
                                    <td>
                                        <strong>@assignment.User?.UserName</strong>
                                        @if (!string.IsNullOrEmpty(assignment.User?.FullName))
                                        {
                                            <br /><small class="text-muted">@assignment.User.FullName</small>
                                        }
                                    </td>
                                    <td>
                                        <strong>@assignment.Learning?.Title</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@assignment.Learning?.Category</span>
                                    </td>
                                    <td>
                                        @if (assignment.Status == "Completed")
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check-circle"></i> Completed
                                            </span>
                                        }
                                        else if (assignment.Status == "InProgress")
                                        {
                                            <span class="badge bg-info">
                                                <i class="fas fa-spinner"></i> In Progress
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="fas fa-circle"></i> Not Started
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="progress flex-grow-1" style="height: 18px; min-width: 80px;">
                                                <div class="progress-bar @(assignment.Status == "Completed" ? "bg-success" : assignment.Status == "InProgress" ? "bg-info" : "bg-secondary")" 
                                                     role="progressbar" 
                                                     style="width: @(assignment.ProgressPercentage ?? 0)%"
                                                     aria-valuenow="@(assignment.ProgressPercentage ?? 0)" 
                                                     aria-valuemin="0" 
                                                     aria-valuemax="100">
                                                    <small>@(assignment.ProgressPercentage ?? 0)%</small>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <small>@assignment.AssignedDate.ToString("MMM dd, yyyy")</small>
                                    </td>
                                    <td>
                                        <small class="@(isOverdue ? "text-danger fw-bold" : "")">
                                            @assignment.DueDate.ToString("MMM dd, yyyy")
                                        </small>
                                    </td>
                                    <td>
                                        @if (assignment.Status == "Completed")
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check"></i> Done
                                            </span>
                                        }
                                        else if (isOverdue)
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-exclamation-triangle"></i> @Math.Abs(daysLeft) days overdue
                                            </span>
                                        }
                                        else if (daysLeft <= 7)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="fas fa-clock"></i> @daysLeft days
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark">
                                                @daysLeft days
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <a class="btn btn-sm btn-info" 
                                           asp-action="TeamMemberDetail" 
                                           asp-route-id="@assignment.UserId"
                                           title="View member details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination Controls -->
                @if (allAssignments.TotalPages > 1)
                {
                    <nav aria-label="Page navigation" class="mt-3">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(!allAssignments.HasPreviousPage ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(allAssignments.PageIndex - 1)" asp-route-pageSize="@allAssignments.PageSize">
                                    <i class="fas fa-chevron-left"></i> Previous
                                </a>
                            </li>

                            @for (int i = 1; i <= allAssignments.TotalPages; i++)
                            {
                                <li class="page-item @(i == allAssignments.PageIndex ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-pageSize="@allAssignments.PageSize">@i</a>
                                </li>
                            }

                            <li class="page-item @(!allAssignments.HasNextPage ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(allAssignments.PageIndex + 1)" asp-route-pageSize="@allAssignments.PageSize">
                                    Next <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                        <div class="text-center text-muted">
                            <small>
                                Showing @((allAssignments.PageIndex - 1) * allAssignments.PageSize + 1) 
                                to @Math.Min(allAssignments.PageIndex * allAssignments.PageSize, allAssignments.TotalCount) 
                                of @allAssignments.TotalCount assignments
                            </small>
                        </div>
                    </nav>
                }
            </div>
        </div>
    }

    <!-- Team Members Table -->
    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-primary text-white">
            <h6 class="m-0 font-weight-bold">
                <i class="fas fa-users"></i> Your Team Members
            </h6>
        </div>
        <div class="card-body">
            @if (teamMembers.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Username</th>
                                <th>Full Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Assignments</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in teamMembers)
                            {
                                var stats = memberStats.ContainsKey(member.Id) ? memberStats[member.Id] : null;
                                var memberAssignments = stats?.TotalAssignments ?? 0;
                                var memberCompleted = stats?.CompletedAssignments ?? 0;
                                var memberOverdue = stats?.OverdueAssignments ?? 0;

                                <tr>
                                    <td>
                                        <strong>@member.UserName</strong>
                                    </td>
                                    <td>@(member.FullName ?? "-")</td>
                                    <td>@(member.Email ?? "-")</td>
                                    <td>
                                        <span class="badge bg-primary">@member.Role</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@memberAssignments Total</span>
                                        <span class="badge bg-success">@memberCompleted Done</span>
                                        @if (memberOverdue > 0)
                                        {
                                            <span class="badge bg-danger">@memberOverdue Overdue</span>
                                        }
                                    </td>
                                    <td>
                                        <a class="btn btn-sm btn-info" 
                                           asp-action="TeamMemberDetail" 
                                           asp-route-id="@member.Id"
                                           title="View learning assignments">
                                            <i class="fas fa-eye"></i> View Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    <i class="fas fa-info-circle"></i> No team members assigned to you yet.
                </div>
            }
        </div>
    </div>
</div>

<style>
    .card.border-left-primary {
        border-left: 0.25rem solid #4e73df !important;
    }
    .card.border-left-success {
        border-left: 0.25rem solid #1cc88a !important;
    }
    .card.border-left-info {
        border-left: 0.25rem solid #36b9cc !important;
    }
    .card.border-left-warning {
        border-left: 0.25rem solid #f6c23e !important;
    }
    .text-primary { color: #4e73df !important; }
    .text-success { color: #1cc88a !important; }
    .text-info { color: #36b9cc !important; }
    .text-warning { color: #f6c23e !important; }
    .font-weight-bold { font-weight: 700 !important; }
    .text-xs {
        font-size: 0.7rem;
    }
    .text-gray-300 {
        color: #dddfeb !important;
    }
    .table-sm td, .table-sm th {
        padding: 0.5rem;
        font-size: 0.875rem;
    }
</style>