@{
    ViewData["Title"] = "Learning Platform";
}

@section Styles {
    <style>
        .hero-section {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            padding: 4rem 0;
            border-bottom: 4px solid var(--industrial-accent);
        }
        .hero-title {
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--industrial-text);
            margin-bottom: 1.5rem;
        }
        .hero-subtitle {
            font-size: 1.3rem;
            color: #6c757d;
            margin-bottom: 2rem;
            font-weight: 500;
        }
        .description-section {
            background: white;
            padding: 3rem 0;
            border-bottom: 4px solid #e9ecef;
        }
        .description-text {
            font-size: 1.1rem;
            line-height: 1.8;
            color: var(--industrial-text);
            text-align: justify;
        }
        .btn-sign-in {
            background: var(--industrial-accent);
            color: white;
            border: none;
            padding: 1rem 3rem;
            font-size: 1.2rem;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 1.5px;
            transition: all 0.3s;
            border-radius: 0;
            box-shadow: 0 4px 6px rgba(255, 107, 53, 0.3);
        }
        .btn-sign-in:hover {
            background: #e55a2b;
            transform: translateY(-3px);
            box-shadow: 0 6px 12px rgba(255, 107, 53, 0.4);
            color: white;
        }
        .industrial-card {
            border: 3px solid #e9ecef;
            border-radius: 0;
            transition: all 0.3s;
            background: white;
        }
        .industrial-card:hover {
            border-color: var(--industrial-accent);
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.1);
        }
        .card-icon {
            font-size: 3.5rem;
            margin-bottom: 1.5rem;
        }
        .section-title {
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--industrial-text);
            margin-bottom: 2rem;
            position: relative;
            padding-bottom: 1rem;
        }
        .section-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 4px;
            background: var(--industrial-accent);
        }
        .feature-list {
            list-style: none;
            padding: 0;
        }
        .feature-list li {
            padding: 0.5rem 0;
            font-size: 1rem;
            font-weight: 500;
        }
        .feature-list i {
            color: var(--industrial-accent);
            margin-right: 10px;
        }
    </style>
}

<div class="hero-section">
    <div class="container text-center">
        <h1 class="hero-title">Learning Platform</h1>
        <p class="hero-subtitle">Enterprise Training & Development Management System</p>

        @if (User?.Identity?.IsAuthenticated ?? false)
        {
            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                @if (User.IsInRole("Employee"))
                {
                    <a class="btn btn-sign-in" asp-controller="Employee" asp-action="Index">
                        <i class="fas fa-graduation-cap"></i> DASHBOARD
                    </a>
                }
                @if (User.IsInRole("Manager"))
                {
                    <a class="btn btn-sign-in" asp-controller="Manager" asp-action="Index">
                        <i class="fas fa-users"></i> MANAGER PORTAL
                    </a>
                }
                @if (User.IsInRole("HR"))
                {
                    <a class="btn btn-sign-in" asp-controller="HR" asp-action="Index">
                        <i class="fas fa-cogs"></i> HR PORTAL
                    </a>
                }
            </div>
        }
        else
        {
            <a class="btn btn-sign-in" asp-controller="Account" asp-action="Login">
                <i class="fas fa-sign-in-alt"></i> SIGN IN
            </a>
        }
    </div>
</div>

<div class="description-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <h2 class="section-title text-center">ABOUT THE PLATFORM</h2>
                <p class="description-text mb-4">
                    The Learning Platform is a comprehensive enterprise-grade Learning Management System (LMS) designed to streamline 
                    employee training, skill development, and certification tracking across your organization. Built with modern .NET 
                    technologies, this platform provides a robust, secure, and scalable solution for managing learning initiatives.
                </p>
                <p class="description-text mb-4">
                    Our system supports role-based access control with three distinct user roles: Employees who can access and complete 
                    assigned courses, Managers who can assign learning paths and monitor team progress, and HR Administrators who maintain 
                    full control over the learning ecosystem including user management, course creation, and organization-wide analytics.
                </p>
                <div class="row mt-5">
                    <div class="col-md-6">
                        <h5 class="fw-bold mb-3"><i class="fas fa-check-circle text-success me-2"></i>KEY FEATURES</h5>
                        <ul class="feature-list">
                            <li><i class="fas fa-arrow-right"></i> Course assignment and tracking</li>
                            <li><i class="fas fa-arrow-right"></i> Interactive assessments and quizzes</li>
                            <li><i class="fas fa-arrow-right"></i> Progress monitoring and reporting</li>
                            <li><i class="fas fa-arrow-right"></i> Certificate generation and management</li>
                            <li><i class="fas fa-arrow-right"></i> Team performance analytics</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <h5 class="fw-bold mb-3"><i class="fas fa-shield-alt text-primary me-2"></i>TECHNICAL HIGHLIGHTS</h5>
                        <ul class="feature-list">
                            <li><i class="fas fa-arrow-right"></i> Built on ASP.NET Core MVC (.NET 8)</li>
                            <li><i class="fas fa-arrow-right"></i> Entity Framework Core for data access</li>
                            <li><i class="fas fa-arrow-right"></i> Role-based authentication & authorization</li>
                            <li><i class="fas fa-arrow-right"></i> Responsive Bootstrap UI design</li>
                            <li><i class="fas fa-arrow-right"></i> SQL Server database backend</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <h2 class="section-title text-center">USER ROLES</h2>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="industrial-card card h-100">
                <div class="card-body text-center p-4">
                    <i class="fas fa-user-graduate card-icon" style="color: #0d6efd;"></i>
                    <h5 class="card-title fw-bold mb-3">EMPLOYEE</h5>
                    <p class="card-text">Access courses, take assessments, and track your progress</p>
                    <hr>
                    <ul class="text-start feature-list">
                        <li><i class="fas fa-check"></i> View assigned courses</li>
                        <li><i class="fas fa-check"></i> Complete assessments</li>
                        <li><i class="fas fa-check"></i> Download certificates</li>
                        <li><i class="fas fa-check"></i> Track learning history</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="industrial-card card h-100">
                <div class="card-body text-center p-4">
                    <i class="fas fa-users card-icon" style="color: #198754;"></i>
                    <h5 class="card-title fw-bold mb-3">MANAGER</h5>
                    <p class="card-text">Assign courses and monitor your team's development</p>
                    <hr>
                    <ul class="text-start feature-list">
                        <li><i class="fas fa-check"></i> Assign learning paths</li>
                        <li><i class="fas fa-check"></i> Monitor team progress</li>
                        <li><i class="fas fa-check"></i> View performance metrics</li>
                        <li><i class="fas fa-check"></i> Generate team reports</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="industrial-card card h-100">
                <div class="card-body text-center p-4">
                    <i class="fas fa-cogs card-icon" style="color: #0dcaf0;"></i>
                    <h5 class="card-title fw-bold mb-3">HR ADMIN</h5>
                    <p class="card-text">Manage users and view organization-wide reports</p>
                    <hr>
                    <ul class="text-start feature-list">
                        <li><i class="fas fa-check"></i> Manage all users</li>
                        <li><i class="fas fa-check"></i> Create course catalog</li>
                        <li><i class="fas fa-check"></i> Organization analytics</li>
                        <li><i class="fas fa-check"></i> System configuration</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
